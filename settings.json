{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git:add)",
      "Bash(git:commit)",
      "Bash(git:push)",
      "Bash(git:pull)",
      "Bash(git:status)",
      "Bash(git:log)",
      "Bash(git:diff)",
      "Bash(git:branch)",
      "Bash(git:checkout)",
      "Bash(git:merge)",
      "Bash(git:stash)",
      "Bash(git:tag)",
      "Bash(git:fetch)",
      "Bash(git:clone)",
      "Bash(git:submodule)",
      "Bash(pip:show)",
      "Bash(pip:list)",
      "Bash(pip:freeze)",
      "Bash(conda:env)",
      "Bash(conda:list)",
      "Bash(conda:info)",
      "Bash(python:--version)",
      "Bash(which:*)",
      "Bash(cd:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(git:reset)",
      "Bash(git:rebase)",
      "Bash(git:push:--force)"
    ]
  },
  "enabledPlugins": {
    "explanatory-output-style@claude-plugins-official": true,
    "mgrep@Mixedbread-Grep": true
  }
}
