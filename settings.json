{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git:add)",
      "Bash(git:commit)",
      "Bash(git:push)",
      "Bash(git:pull)",
      "Bash(git:status)",
      "Bash(git:log)",
      "Bash(git:diff)",
      "Bash(git:branch)",
      "Bash(git:checkout)",
      "Bash(git:merge)",
      "Bash(git:stash)",
      "Bash(git:tag)",
      "Bash(git:fetch)",
      "Bash(git:clone)",
      "Bash(git:submodule)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(git:reset)",
      "Bash(git:rebase)",
      "Bash(git:push:--force)"
    ]
  }
}
